# NexSec example environment variables
# Copy this file to .env.local (or .env) and fill in values. Do NOT commit secrets.

# OpenAI / LLM
OPENAI_API_KEY=REPLACE_ME
GEMINI_API_KEY=REPLACE_ME
ANTHROPIC_API_KEY=REPLACE_ME
SIYARIX_OLLAMA_URL=http://localhost:11434

# NexSec server (if using remote server)
SIYARIX_SERVER_URL=
SIYARIX_API_KEY=

# Config and plugins directories (optional)
SIYARIX_CONFIG_DIR=
SIYARIX_PLUGINS_DIR=

# Feature flags / runtime
SIYARIX_AUDIT_VERBOSE=0
SIYARIX_FAST_DISCOVERY=0
SIYARIX_NO_BANNER=0

# CI flag
CI=0
